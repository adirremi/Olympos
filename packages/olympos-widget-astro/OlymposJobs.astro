---
/**
 * Olympos Sync — server-rendered job gallery for Astro.
 *
 * Fetches a business's published check-ins at request/build time and renders
 * them as real, crawlable HTML plus JSON-LD structured data — directly in your
 * page's source (no iframe), so Google indexes the jobs on your own domain.
 *
 * Usage:
 *   ---
 *   import OlymposJobs from "@olympos/widget-astro/OlymposJobs.astro";
 *   ---
 *   <OlymposJobs businessId="YOUR_BUSINESS_ID" />
 */
export interface Props {
  businessId: string;
  baseUrl?: string;
  limit?: number;
}

type Media = { url: string; type: "image" | "video" };
type Job = {
  id: string;
  full_address: string;
  description: string | null;
  created_at: string;
  media: Media[];
};
type WidgetData = {
  business: { id: string; name: string } | null;
  check_ins: Job[];
};

const {
  businessId,
  baseUrl = "https://olympossync.com",
  limit,
} = Astro.props;

let data: WidgetData = { business: null, check_ins: [] };
try {
  const res = await fetch(
    `${baseUrl}/api/widget/${encodeURIComponent(businessId)}`,
  );
  if (res.ok) {
    data = (await res.json()) as WidgetData;
  }
} catch {
  /* render empty state below */
}

const business = data.business;
const jobs = limit ? data.check_ins.slice(0, limit) : data.check_ins;

const images = jobs
  .flatMap((job) => job.media.filter((m) => m.type === "image").map((m) => m.url))
  .slice(0, 30);

const jsonLd = business
  ? {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      name: business.name,
      image: images,
      subjectOf: jobs.slice(0, 30).map((job) => ({
        "@type": "CreativeWork",
        about: job.description || job.full_address,
        contentLocation: { "@type": "Place", address: job.full_address },
        dateCreated: job.created_at,
      })),
    }
  : null;
---

{!business || jobs.length === 0 ? (
  <div class="olv">
    <div class="olv__empty">No published jobs yet.</div>
  </div>
) : (
  <div class="olv">
    <div class="olv__head">
      <h2 class="olv__title">{business.name}</h2>
      <p class="olv__sub">
        {jobs.length} recent job{jobs.length === 1 ? "" : "s"}
      </p>
    </div>

    <div class="olv__grid">
      {jobs.map((job) => {
        const cover = job.media[0];
        const extra = job.media.slice(1, 5);
        return (
          <article class="olv__card">
            {cover && (
              <a class="olv__cover" href={cover.url} target="_blank" rel="noopener noreferrer">
                {cover.type === "video" ? (
                  <video src={cover.url} muted playsinline></video>
                ) : (
                  <img src={cover.url} alt="" loading="lazy" />
                )}
                <span class="olv__badge">
                  {job.media.length > 1 ? `${job.media.length} photos` : "1 photo"}
                </span>
              </a>
            )}
            <div class="olv__body">
              <p class="olv__addr">{job.full_address}</p>
              {job.description && <p class="olv__desc">{job.description}</p>}
              {extra.length > 0 && (
                <div class="olv__thumbs">
                  {extra.map((m) => (
                    <a class="olv__thumb" href={m.url} target="_blank" rel="noopener noreferrer">
                      {m.type === "video" ? (
                        <video src={m.url} muted playsinline></video>
                      ) : (
                        <img src={m.url} alt="" loading="lazy" />
                      )}
                    </a>
                  ))}
                </div>
              )}
              <p class="olv__date">
                {new Date(job.created_at).toLocaleDateString()}
              </p>
            </div>
          </article>
        );
      })}
    </div>

    <div class="olv__foot">
      <a href={baseUrl} target="_blank" rel="noopener noreferrer">
        Powered by Olympos Sync
      </a>
    </div>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </div>
)}

<style>
  .olv {
    --olv-radius: 14px;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto,
      Helvetica, Arial, sans-serif;
    color: #0f172a;
  }
  .olv * {
    box-sizing: border-box;
  }
  .olv__head {
    margin: 0 0 16px;
  }
  .olv__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }
  .olv__sub {
    font-size: 0.875rem;
    color: #64748b;
    margin: 2px 0 0;
  }
  .olv__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }
  .olv__card {
    border: 1px solid #e2e8f0;
    border-radius: var(--olv-radius);
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .olv__card:hover {
    box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.12);
    transform: translateY(-2px);
  }
  .olv__cover {
    position: relative;
    aspect-ratio: 4 / 3;
    background: #f1f5f9;
    overflow: hidden;
    display: block;
  }
  .olv__cover img,
  .olv__cover video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .olv__cover:hover img {
    transform: scale(1.05);
  }
  .olv__badge {
    position: absolute;
    left: 10px;
    top: 10px;
    background: rgba(15, 23, 42, 0.78);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 999px;
  }
  .olv__body {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .olv__addr {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .olv__desc {
    font-size: 0.85rem;
    color: #475569;
    margin: 0;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .olv__thumbs {
    display: flex;
    gap: 6px;
    margin-top: 4px;
  }
  .olv__thumb {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    overflow: hidden;
    background: #f1f5f9;
    flex: 0 0 auto;
    display: block;
  }
  .olv__thumb img,
  .olv__thumb video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .olv__date {
    font-size: 0.75rem;
    color: #94a3b8;
    margin: auto 0 0;
  }
  .olv__foot {
    margin-top: 16px;
    text-align: right;
  }
  .olv__foot a {
    font-size: 0.75rem;
    color: #94a3b8;
    text-decoration: none;
  }
  .olv__foot a:hover {
    color: #475569;
  }
  .olv__empty {
    padding: 32px;
    text-align: center;
    color: #64748b;
    font-size: 0.9rem;
    border: 1px dashed #cbd5e1;
    border-radius: var(--olv-radius);
  }
</style>
